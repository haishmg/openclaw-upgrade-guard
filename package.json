{
  "name": "clawback",
  "version": "0.2.1",
  "description": "Container rehearsal, guarded update, and rollback safety for OpenClaw upgrades.",
  "type": "module",
  "bin": {
    "clawback": "./bin/clawback.js"
  },
  "scripts": {
    "ci": "npm run check && npm run regression:offline",
    "check": "npm test && node bin/clawback.js --help",
    "container:export": "node scripts/export-fixture.js",
    "container:compare": "bash scripts/run-container-comparison.sh",
    "container:rehearse": "bash scripts/run-container-rehearsal.sh",
    "regression:offline": "node scripts/regression-offline.js",
    "report:html": "node scripts/render-report-html.js",
    "suite:pre": "bash scripts/run-upgrade-suite.sh pre",
    "suite:post": "bash scripts/run-upgrade-suite.sh post",
    "test": "node --test test/*.test.js",
    "upgrade:apply": "node scripts/guarded-update.js apply",
    "upgrade:rollback": "node scripts/guarded-update.js rollback"
  },
  "keywords": [
    "openclaw",
    "upgrade",
    "healthcheck",
    "preflight"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
